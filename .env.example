# PMK Child Mobile App - Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=https://api.pmk.com/api/v1
SOCKET_URL=wss://api.pmk.com
API_TIMEOUT=30000

# Firebase Configuration (for Push Notifications)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# App Configuration
APP_NAME=PMK Child
APP_VERSION=1.0.0
APP_ENV=development

# Feature Flags
ENABLE_LOCATION_TRACKING=true
ENABLE_SCREEN_TIME=true
ENABLE_CONTENT_FILTERING=true
ENABLE_EMERGENCY_SOS=true
ENABLE_FAMILY_CHAT=true

# Location Settings
LOCATION_INTERVAL=30000
LOCATION_DISTANCE_FILTER=10
LOCATION_ACCURACY=high

# Sync Settings
SYNC_INTERVAL=300000
MAX_RETRY_ATTEMPTS=5
OFFLINE_RETENTION_DAYS=7

# Debug Settings (Development Only)
ENABLE_DEBUG_LOGS=true
ENABLE_REDUX_LOGGER=true
ENABLE_NETWORK_LOGGER=true
